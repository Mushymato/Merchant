{
  "$schema": "https://smapi.io/schemas/content-patcher.json",
  "Changes": [
    // example for adding dialogue
    {
      "Action": "EditData",
      "Target": "mushymato.Merchant/Customers",
      "TargetField": [
        "Robin",
        "Dialogue"
      ],
      "Entries": {
        "{{ModId}}_Haggle_A": {
          "Haggle_Ask": "A - Ask - Price - {0} - Item {1}",
          "Haggle_Compromise": "A - Compromise - Price - {0} - Item {1}",
          "Haggle_Overpriced": "A - Overpriced - Price - {0} - Item {1}",
          "Haggle_Success": "A - Success - Price - {0} - Item {1}",
          "Haggle_Fail": "A - Fail - Price - {0} - Item {1}"
        },
        "{{ModId}}_Haggle_B": {
          "Haggle_Ask": "B - Ask - Price - {0} - Item {1}",
          "Haggle_Compromise": "B - Compromise - Price - {0} - Item {1}",
          "Haggle_Overpriced": "B - Overpriced - Price - {0} - Item {1}",
          "Haggle_Success": "B - Success - Price - {0} - Item {1}",
          "Haggle_Fail": "B - Fail - Price - {0} - Item {1}"
        }
      }
    },
    // example for changing whether customer appears in shop
    {
      "Action": "EditData",
      "Target": "mushymato.Merchant/Customers",
      "Fields": {
        "Wizard": {
          "Condition": "FALSE",
          "Chance": 0.5
        }
      }
    }
  ]
}
